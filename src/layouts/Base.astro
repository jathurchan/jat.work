---
import '../styles/global.css';
import { meta } from '../lib/site';
import { ClientRouter } from 'astro:transitions';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title?: string;
  description?: string;
  /** Open Graph object type. Posts pass "article"; everything else is a site. */
  ogType?: 'website' | 'article';
  /** Site-relative path to a page-specific OG image (posts pass their generated
      /og/<slug>.png); defaults to the generated site-wide card. */
  ogImage?: string;
}

const {
  title = meta.title,
  description = meta.description,
  ogType = 'website',
  ogImage = '/og/site.png',
} = Astro.props;

// Canonical URL for this page: absolute, normalised to the path only (no query
// or hash) so every page advertises a single self-referential canonical and a
// matching og:url — previously every page shared the site root, which is wrong
// for posts and weakens sharing/SEO.
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url).href;
---

<!doctype html>
<!-- data-theme is server-rendered so theme-gated styles hold without JS; the
     theme script below overrides it before first paint when dark is saved. -->
<html lang="en" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#fcfcfc" />
    <style is:inline>
      /* Cold-load FOUC guard. Every icon on the site is an inline <svg> with
         only a viewBox (no width/height attribute); the main stylesheet — a
         large, render-blocking file — sizes each one. If that sheet is slow to
         arrive, fails, or is mid-swap during a reload, browsers fall back to the
         SVG default of 300x150 and the icons flash as giant glyphs (the stray
         "chat bubble" and friends). Bounding any unsized SVG to a 1em box keeps
         that from ever happening. :where() gives this zero specificity, so the
         real per-icon rules win the instant the stylesheet applies. */
      :where(svg:not([width])) { width: 1em; height: 1em; }
    </style>
    <script is:inline>
      (function() {
        // Apply the saved/preferred theme before first paint. Crucially, re-apply
        // it after every View Transitions swap: navigation replaces <html>, which
        // drops the data-theme attribute. Without this, returning from a post page
        // leaves data-theme unset, so theme-gated styles (e.g. the RaftLock card)
        // fall back to their dark defaults and wash out grey on the light page.
        function applyTheme() {
          var storedTheme = typeof localStorage !== 'undefined' && localStorage.getItem('theme');
          // Default to system preference — use dark if the OS prefers it, otherwise light.
          var theme = storedTheme || (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
          // Safari only reliably re-reads theme-color when the meta node itself is
          // replaced — updating content in-place is often ignored until reload.
          var color = theme === 'dark' ? '#121214' : '#fcfcfc';
          var existing = document.querySelector('meta[name="theme-color"]');
          if (existing) existing.remove();
          var tc = document.createElement('meta');
          tc.name = 'theme-color';
          tc.content = color;
          document.head.prepend(tc);
        }
        applyTheme();
        if (!window.__themeSwapBound) {
          window.__themeSwapBound = true;
          document.addEventListener('astro:after-swap', applyTheme);
        }
      })();
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Jathurchan Selvakumar" />
    <link rel="icon" href="/favicon.svg?v=1" type="image/svg+xml" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title="Jathurchan Selvakumar — Writing" href="/rss.xml" />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    {/* Fonts are self-hosted (see styles/partials/00-fonts.css) so no third-party
        origin gates first paint. Preload the four latin faces that appear above
        the fold on the homepage so they download in parallel with the stylesheet
        instead of after it, closing the fallback-font flash window on a cold
        cache. Fraunces italic left the hero with the old invitation line (the
        manifest is sans + mono), so it loads lazily with the post/footer styles
        that still use it. latin-ext stays lazy too. */}
    <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/outfit-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/jetbrains-mono-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/fraunces-latin.woff2" as="font" type="font/woff2" crossorigin />
    <ClientRouter />
    {/* Vercel Web Analytics — cookieless, no consent banner. Collects data only
        once deployed to Vercel with Web Analytics enabled in the dashboard;
        runs in dev mode locally (logs, sends nothing). */}
    <Analytics />
  </head>
  <body>
    {/* Keyboard users skip the header chrome; visually hidden until focused. */}
    <a class="skip-link" href="#main">Skip to content</a>
    <slot />
  </body>
</html>
