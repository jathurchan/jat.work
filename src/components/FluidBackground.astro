---
---
<div class="fluid-bg-container" aria-hidden="true">
  <canvas id="fluid-canvas"></canvas>
  <div class="page-bg-grid"></div>
</div>

<script>
  class FluidSimulation {
    private canvas: HTMLCanvasElement;
    private ctx: CanvasRenderingContext2D;
    private orbs: any[];
    private mouse: { x: number; y: number; active: boolean };
    private animationFrame: number;
    private colors: string[];
    private scrollVelocity: number;
    private lastScrollY: number;

    constructor() {
      this.canvas = document.getElementById('fluid-canvas') as HTMLCanvasElement;
      if (!this.canvas) return;
      
      this.ctx = this.canvas.getContext('2d', { alpha: true }) as CanvasRenderingContext2D;
      this.orbs = [];
      this.mouse = { x: -1000, y: -1000, active: false };
      this.scrollVelocity = 0;
      this.lastScrollY = window.scrollY;
      
      const css = getComputedStyle(document.documentElement);
      const blue = css.getPropertyValue('--g-blue').trim() || '#4285F4';
      const red = css.getPropertyValue('--g-red').trim() || '#EA4335';
      const yellow = css.getPropertyValue('--g-yellow').trim() || '#FBBC05';
      const green = css.getPropertyValue('--g-green').trim() || '#34A853';
      // Weighted toward the cool brand hues (blue + green) for a calm, cohesive
      // wash; red appears as an occasional accent and amber only once, so the
      // overlapping orbs never blur into a muddy orange.
      this.colors = [blue, green, blue, green, blue, red, green, yellow];

      this.resize = this.resize.bind(this);
      this.animate = this.animate.bind(this);
      this.handlePointerMove = this.handlePointerMove.bind(this);
      this.handlePointerLeave = this.handlePointerLeave.bind(this);
      this.handleScroll = this.handleScroll.bind(this);
      
      this.init();
    }

    private init() {
      window.addEventListener('resize', this.resize);
      window.addEventListener('pointermove', this.handlePointerMove);
      window.addEventListener('pointerleave', this.handlePointerLeave);
      window.addEventListener('scroll', this.handleScroll, { passive: true });
      
      this.resize();
      this.createOrbs();
      this.animate();
    }

    private resize() {
      const dpr = window.devicePixelRatio || 1;
      this.canvas.width = window.innerWidth * dpr;
      this.canvas.height = Math.max(window.innerHeight * 1.3, 1000) * dpr;
      this.ctx.scale(dpr, dpr);
    }

    private createOrbs() {
      const isMobile = window.innerWidth < 768;
      const numOrbs = isMobile ? 9 : 14;

      for (let i = 0; i < numOrbs; i++) {
        const r = Math.random() * 220 + (isMobile ? 120 : 180);
        this.orbs.push({
          x: Math.random() * window.innerWidth,
          y: Math.random() * (window.innerHeight * 1.2),
          // Slow, calm drift — half the previous speed so the field reads as an
          // ambient wash rather than restless blobs.
          vx: (Math.random() - 0.5) * 0.8,
          vy: (Math.random() - 0.5) * 0.8,
          radius: r,
          baseRadius: r,
          color: this.colors[i % this.colors.length],
          phase: Math.random() * Math.PI * 2
        });
      }
    }

    private handlePointerMove(e: PointerEvent) {
      this.mouse.x = e.clientX;
      this.mouse.y = e.clientY + window.scrollY;
      this.mouse.active = true;
    }

    private handleScroll() {
      const current = window.scrollY;
      this.scrollVelocity = current - this.lastScrollY;
      this.lastScrollY = current;
    }

    private handlePointerLeave() {
      this.mouse.active = false;
    }

    private animate() {
      this.ctx.clearRect(0, 0, this.canvas.width, this.canvas.height);
      
      const width = window.innerWidth;
      const height = this.canvas.height / (window.devicePixelRatio || 1);
      
      // Decay velocity so the squish settles smoothly
      this.scrollVelocity *= 0.9;
      const stretch = Math.min(1.4, 1 + Math.abs(this.scrollVelocity) * 0.004);

      for (let i = 0; i < this.orbs.length; i++) {
        const orb = this.orbs[i];
        
        orb.x += orb.vx;
        orb.y += orb.vy;
        
        orb.phase += 0.009;
        orb.radius = orb.baseRadius + Math.sin(orb.phase) * 28;

        if (this.mouse.active) {
          const dx = this.mouse.x - orb.x;
          const dy = this.mouse.y - orb.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          const maxDist = 320;

          if (dist < maxDist) {
            const force = (maxDist - dist) / maxDist;
            // Gentler parallax pull so the cursor nudges the field softly.
            orb.x -= (dx / dist) * force * 2.2;
            orb.y -= (dy / dist) * force * 2.2;
          }
        }

        if (orb.x < -orb.radius) orb.vx *= -1;
        if (orb.x > width + orb.radius) orb.vx *= -1;
        if (orb.y < -orb.radius) orb.vy *= -1;
        if (orb.y > height + orb.radius) orb.vy *= -1;

        const gradient = this.ctx.createRadialGradient(
          orb.x, orb.y, 0,
          orb.x, orb.y, orb.radius
        );
        
        let c = orb.color;
        if (c.startsWith('#')) {
           const r = parseInt(c.slice(1, 3), 16);
           const g = parseInt(c.slice(3, 5), 16);
           const b = parseInt(c.slice(5, 7), 16);
           gradient.addColorStop(0, `rgba(${r}, ${g}, ${b}, 0.55)`);
           gradient.addColorStop(0.6, `rgba(${r}, ${g}, ${b}, 0.16)`);
           gradient.addColorStop(1, `rgba(${r}, ${g}, ${b}, 0)`);
        } else {
           gradient.addColorStop(0, orb.color);
           gradient.addColorStop(1, 'transparent');
        }

        this.ctx.save();
        this.ctx.translate(orb.x, orb.y);
        // Apply vertical stretch based on scroll velocity (preserving rough volume)
        this.ctx.scale(1 / stretch, stretch);
        this.ctx.translate(-orb.x, -orb.y);

        this.ctx.beginPath();
        this.ctx.arc(orb.x, orb.y, orb.radius, 0, Math.PI * 2);
        this.ctx.fillStyle = gradient;
        this.ctx.fill();
        this.ctx.restore();
      }

      this.animationFrame = requestAnimationFrame(this.animate);
    }
  }

  const initFluid = () => {
    new FluidSimulation();
  };
  
  initFluid();
  document.addEventListener('astro:page-load', initFluid);
</script>

<style>
  .fluid-bg-container {
    position: absolute;
    top: -12vh;
    left: -10%;
    right: -10%;
    height: 132vh;
    z-index: -1;
    overflow: hidden;
    pointer-events: none;
    filter: blur(52px) saturate(112%);
    opacity: 0.46;
    /* Two masks compose: a vertical fade that dissolves the field down the page,
       intersected with a radial "clearing" that thins the colour right where the
       hero copy sits — so the wash lives at the edges and text keeps its
       contrast. */
    -webkit-mask-image:
      radial-gradient(120% 75% at 50% 30%, transparent 0%, transparent 28%, #000 62%),
      linear-gradient(to bottom, #000 0, #000 52%, transparent 96%);
    -webkit-mask-composite: source-in;
    mask-image:
      radial-gradient(120% 75% at 50% 30%, transparent 0%, transparent 28%, #000 62%),
      linear-gradient(to bottom, #000 0, #000 52%, transparent 96%);
    mask-composite: intersect;
  }

  :global(:root[data-theme="dark"]) .fluid-bg-container {
    /* Dark mode carries the colour better, so let it read a touch stronger. */
    opacity: 0.5;
    filter: blur(56px) saturate(122%);
  }

  #fluid-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .page-bg-grid {
    position: absolute;
    inset: 0;
    background-size: 46px 46px;
    background-image:
      linear-gradient(to right, color-mix(in srgb, var(--ink) 6%, transparent) 1px, transparent 1px),
      linear-gradient(to bottom, color-mix(in srgb, var(--ink) 6%, transparent) 1px, transparent 1px);
    -webkit-mask-image: linear-gradient(to bottom, #000 0, #000 50vh, color-mix(in srgb, #000 18%, transparent) 118vh);
    mask-image: linear-gradient(to bottom, #000 0, #000 50vh, color-mix(in srgb, #000 18%, transparent) 118vh);
    opacity: 0.6;
    z-index: 1;
  }

  :global(:root[data-theme="dark"]) .page-bg-grid {
    background-image:
      linear-gradient(to right, color-mix(in srgb, #ffffff 7%, transparent) 1px, transparent 1px),
      linear-gradient(to bottom, color-mix(in srgb, #ffffff 7%, transparent) 1px, transparent 1px);
    opacity: 0.5;
  }
</style>
