---
import { career, careerHead, careerStart } from '../lib/site';

// Chronological, start → now: scrolling DOWN walks the path forward in time.
const path = career;

// Bespoke glyph per experience — drawn from the PRODUCT each role shipped, on
// a glassy, brand-tinted disc instead of a corporate logo. 24×24, stroke-based
// to match the icon language used across the site. Only glyphs actually
// referenced by site.yaml live here.
const symbols: Record<string, string> = {
  // Amazon DynamoDB — the database cylinder, energised by the service's bolt.
  dynamo:
    '<ellipse cx="12" cy="5.6" rx="7.5" ry="2.9"/><path d="M4.5 5.6v12.8c0 1.6 3.36 2.9 7.5 2.9s7.5-1.3 7.5-2.9V5.6"/><path d="M13.3 9.6l-2.7 4.3h2.8l-2.7 4.3"/>',
  // DynamoDB under watch — the same store, its health trace running through it
  // (the monitoring internship: canaries on the metadata store).
  'dynamo-watch':
    '<ellipse cx="12" cy="5.6" rx="7.5" ry="2.9"/><path d="M4.5 5.6v12.8c0 1.6 3.36 2.9 7.5 2.9s7.5-1.3 7.5-2.9V5.6"/><path d="M7 13.8h1.9l1.2-2.7 1.9 4.7 1.3-2.7H17"/>',
  // Withings HealthMate — a heart with the pulse traced through it.
  health:
    '<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.51 4.04 3 5.5l7 7Z"/><path d="M3.22 12H9.5l.5-1 2 4.5 2-7 1.5 3.5h5.27"/>',
  // Seller Central — the marketplace cart, drawn whole: frame, basket, wheels.
  cart:
    '<circle cx="8" cy="20.5" r="1.5"/><circle cx="18" cy="20.5" r="1.5"/><path d="M2.5 3.5h2.2l2.5 11.6a2 2 0 0 0 2 1.6h7.6a2 2 0 0 0 1.95-1.55L20.5 8H6"/>',
  // RaftLock — a padlock.
  lock:
    '<rect x="4.5" y="10.5" width="15" height="9.5" rx="2.2"/><path d="M8 10.5V7.5a4 4 0 0 1 8 0v3"/><circle cx="12" cy="15" r="1.4"/>',
  // Google SRE — a dashboard of live signals.
  observability:
    '<rect x="3" y="4.5" width="18" height="13" rx="2.2"/><path d="M7 13.5l2.5-3 2.5 2L17 8"/><path d="M8.5 21h7M12 17.5V21"/>',
};
---

<section id="experience" class="route-section">
  <div class="section-lead section-rise">
    <span class="featured-eyebrow">{careerHead.eyebrow}</span>
    <h2 class="featured-lead-text">{careerHead.lead}</h2>
  </div>

  <div class="route" aria-label="Career path, earliest to now">
    <!-- the line that draws itself as you scroll -->
    <div class="route-spine" aria-hidden="true">
      <div class="route-spine-fill"></div>
    </div>

    <!-- start cap -->
    <div class="route-origin">
      <span class="route-origin-dot" aria-hidden="true"></span>
      <div class="route-origin-text">
        <span class="route-origin-kicker">{careerStart.kicker}</span>
        <div class="route-origin-line" set:html={careerStart.line} />
      </div>
    </div>

    <ol class="route-list">
      {
        path.map((c) => {
          const variant = c.variant ?? 'station';
          return (
            <li
              class={`route-stop route-stop--${variant}${c.now ? ' is-now' : ''}`}
              style={`--brand: ${c.brand || c.color};`}
            >
              {/* connector narration — the decision that led here */}
              {c.transitionIn && (
                <p class="route-transition">
                  <span class="route-transition-mark" aria-hidden="true">↳</span>
                  <span set:html={c.transitionIn} />
                </p>
              )}

              {/* station marker on the spine */}
              <span class="route-node" role="img" aria-label={c.org}>
                {variant === 'branch' && <span class="route-fork" aria-hidden="true"></span>}
                <span class="route-node-disc">
                  <span class="route-node-sheen" aria-hidden="true"></span>
                  <svg
                    class="route-node-sym"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.7"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                    set:html={symbols[c.symbol ?? ''] ?? ''}
                  />
                </span>
                {c.now && <span class="route-node-ping" aria-hidden="true"></span>}
              </span>

              {/* the card */}
              <article class="route-card">
                <header class="route-card-head">
                  {/* Stations carry a plain chapter index; the branch is already
                      labelled by its tag, so it doesn't get a second badge. */}
                  {variant !== 'branch' && (
                    <span class="route-chapter">{c.chapter}</span>
                  )}
                  {c.tag && <span class="route-tag">{c.tag}</span>}
                  <div class="route-period">
                    {c.now && <span class="route-now">live</span>}
                    <span>{c.period}</span>
                  </div>
                </header>

                <div class="route-identity">
                  <span class="route-org">{c.org}</span>
                  <h3 class="route-role">{c.role}</h3>
                  {c.place && <span class="route-place">{c.place}</span>}
                </div>

                {(c.story || c.heroMetric) && (
                  <div class="route-body">
                    {c.story && <p class="route-story">{c.story}</p>}
                    {c.heroMetric && (
                      <div class="route-metric">
                        <span class="route-metric-val">{c.heroMetric.value}</span>
                        <span class="route-metric-label">{c.heroMetric.label}</span>
                      </div>
                    )}
                  </div>
                )}

                {c.terminal && (
                  /* Destination "what's next" terminal — a live, open-ended hook
                     in place of a finished tech-chip stack. Decorative, so it's
                     hidden from assistive tech. */
                  <div class="route-terminal" aria-hidden="true">
                    <div class="route-terminal-body">
                      <p class="route-terminal-line"><span class="route-term-prompt">$</span> status</p>
                      <p class="route-terminal-line"><span class="route-term-ok">▸</span> all systems go</p>
                      <p class="route-terminal-line"><span class="route-term-prompt">$</span> <span class="route-term-typed">what's next…</span></p>
                    </div>
                  </div>
                )}

                {(c.stack?.length || c.product) && (
                  <footer class="route-card-foot">
                    {c.stack && c.stack.length > 0 && (
                      <ul class="route-stack" aria-label="Tech stack">
                        {c.stack.map((t) => (
                          <li class="route-tech">{t}</li>
                        ))}
                      </ul>
                    )}
                    {c.product && (
                      c.demo ? (
                        <button
                          type="button"
                          class="route-product"
                          data-raft-act="open-fullscreen"
                          data-raft-launch-mode="tour"
                        >
                          <span>{c.product.label}</span>
                          <span aria-hidden="true" class="route-product-arrow">→</span>
                        </button>
                      ) : (
                        <a
                          href={c.product.href}
                          target="_blank"
                          rel="noopener"
                          class="route-product"
                        >
                          <span>{c.product.label}</span>
                          <span aria-hidden="true" class="route-product-arrow">↗</span>
                        </a>
                      )
                    )}
                  </footer>
                )}

                {c.terminus && (
                  <div class="route-terminus" aria-hidden="true">
                    <span class="route-terminus-cap"></span>
                    <span class="route-terminus-text">{c.terminus}</span>
                  </div>
                )}
              </article>
            </li>
          );
        })
      }
    </ol>
  </div>
</section>
