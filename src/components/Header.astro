---
import { profile, nav } from '../lib/site';
import { sectionIcons } from '../lib/icons';
import Wordmark from './Wordmark.astro';

interface Props {
  /** Show the in-page section nav. Only the home page has these anchors. */
  sections?: boolean;
  /** Show a back button. Used on article pages. */
  backButton?: boolean;
}
const { sections = false, backButton = false } = Astro.props;
---


<header class={`site-header reveal-down ${backButton ? 'fast' : ''}`}>
  <div class="site-header-inner shell">
    {/* Left: brand + (home-only) section nav, grouped together. */}
    <div class="header-left">
      <Wordmark />

      {sections && (
        <nav class="section-menu is-default" aria-label="Sections" data-section-menu>
          <button
            type="button"
            class="section-menu-btn"
            aria-expanded="false"
            aria-controls="section-menu-list"
          >
            <svg class="wayfinder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="8" class="wayfinder-ring"></circle>
              <circle cx="12" cy="12" r="2.5" class="wayfinder-dot" fill="currentColor"></circle>
            </svg>
            <span class="section-menu-label" data-current-label>Go to</span>
            <svg class="section-menu-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <ul class="section-menu-list" id="section-menu-list" hidden>
            {nav.sections.map((s) => (
              <li>
                <a class="section-menu-item" href={`#${s.id}`} data-spy={s.id}>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={sectionIcons[s.id] ?? ''} />
                  {s.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )}

      {backButton && (
        <a
          href="/"
          class="header-back-btn"
          aria-label="Go back"
        >
          <svg class="back-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          <span class="back-text">Back</span>
          <svg class="read-ring" viewBox="0 0 24 24" aria-hidden="true">
            <circle class="ring-track" cx="12" cy="12" r="10"></circle>
            <circle class="ring-fill" cx="12" cy="12" r="10"></circle>
          </svg>
        </a>
      )}
    </div>

    {/* Right: a single "let's talk" CTA (→ the footer, where the socials and
        email live), plus résumé download and the theme toggle. */}
    <nav aria-label="Actions" class="nav-row">
      <a href="#contact" class="header-cta">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5Z"></path>
        </svg>
        <span>Let's talk</span>
      </a>

      {profile.resume && (
        <a href={profile.resume} target="_blank" rel="noopener" class="resume-btn" aria-label="Download résumé (PDF)">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.7"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5"></path>
            <g class="tray">
              <path d="M7.5 12l4.5 4.5 4.5-4.5"></path>
              <path d="M12 3v13.5"></path>
            </g>
          </svg>
          <span>Résumé</span>
        </a>
      )}

      {/* Divider always separates the primary action(s) from the theme utility. */}
      <span class="nav-divider" aria-hidden="true"></span>

      <button
        id="theme-toggle"
        class="theme-btn"
        aria-label="Toggle dark theme"
        type="button"
      >
        <!-- Sun Icon (visible in dark mode) -->
        <svg class="sun-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2"></path>
          <path d="M12 20v2"></path>
          <path d="m4.93 4.93 1.41 1.41"></path>
          <path d="m17.66 17.66 1.41 1.41"></path>
          <path d="M2 12h2"></path>
          <path d="M20 12h2"></path>
          <path d="m6.34 17.66-1.41 1.41"></path>
          <path d="m19.07 4.93-1.41 1.41"></path>
        </svg>
        <!-- Moon Icon (visible in light mode) -->
        <svg class="moon-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
        </svg>
      </button>
    </nav>
  </div>
</header>

<script>
  // Delegated on document so it keeps working across View Transitions swaps
  // (the button element is replaced on navigation, but document persists).
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('#theme-toggle');
    if (!btn) return;
    const current = document.documentElement.getAttribute('data-theme');
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    const color = next === 'dark' ? '#121214' : '#fcfcfc';
    const existing = document.querySelector('meta[name="theme-color"]');
    if (existing) existing.remove();
    const tc = document.createElement('meta');
    tc.name = 'theme-color';
    tc.content = color;
    document.head.prepend(tc);
  });

  // Back button (post pages). Delegated on document so it survives View
  // Transitions swaps (the button element is replaced on navigation).
  //
  // The anchor's href="/" is the no-JS / deep-link fallback: someone who opened
  // the post directly (or from an external link) is taken to the home page.
  // When the visitor reached the post from elsewhere on the site, we instead
  // step back through history so the home page is restored at the exact scroll
  // position and section they left — Astro's router handles that on popstate.
  // We detect "came from the site" via history.state.index, which Astro stamps
  // as 0 on a fresh load and increments on each in-app navigation.
  //
  // Registered in the CAPTURE phase so it runs before Astro's own (bubble-phase)
  // link interceptor: when we choose to go back, preventDefault() both stops the
  // browser's default "/" navigation and signals Astro to skip the link, leaving
  // history.back() as the single source of truth. For the deep-link case we do
  // nothing and let Astro client-navigate to "/" as usual.
  document.addEventListener(
    'click',
    (e) => {
      const back = (e.target as HTMLElement).closest('.header-back-btn');
      if (!back) return;
      const state = history.state as { index?: number } | null;
      const index = state && typeof state.index === 'number' ? state.index : 0;
      if (index > 0) {
        e.preventDefault();
        history.back();
      }
      // else: let the href="/" navigation proceed.
    },
    true,
  );
</script>
