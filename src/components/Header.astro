---
import { nav } from '../lib/site';
import { sectionIcons } from '../lib/icons';
import Wordmark from './Wordmark.astro';

interface Props {
  /** Show the in-page section nav. Only the home page has these anchors. */
  sections?: boolean;
  /** Show the reading-progress ring. Used on article pages. */
  reading?: boolean;
}
const { sections = false, reading = false } = Astro.props;
---


{/* No entrance animation on the header: chrome is simply present — the hero
    content is the entrance. (It also means the nav is usable immediately.) */}
<header class="site-header">
  <div class="site-header-inner shell">
    {/* Left: brand + (home-only) section nav, grouped together. */}
    <div class="header-left">
      <Wordmark />

      {sections && (
        <nav class="section-menu is-default" aria-label="Sections" data-section-menu>
          <button
            type="button"
            class="section-menu-btn"
            aria-expanded="false"
            aria-controls="section-menu-list"
          >
            <svg class="wayfinder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="8" class="wayfinder-ring"></circle>
              <circle cx="12" cy="12" r="2.5" class="wayfinder-dot" fill="currentColor"></circle>
            </svg>
            <span class="section-menu-label" data-current-label>Go to</span>
            <svg class="section-menu-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <ul class="section-menu-list" id="section-menu-list" hidden>
            {nav.sections.map((s) => (
              <li>
                <a class="section-menu-item" href={`#${s.id}`} data-spy={s.id}>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={sectionIcons[s.id] ?? ''} />
                  {s.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      )}

      {/* Reading progress, standalone. The old "Back" button around it was
          redundant chrome — the wordmark already leads home and the browser
          owns "back" — and it cost the ring its spot on phones. Decorative to
          assistive tech (the article itself is the source of truth). */}
      {reading && (
        <span class="header-reading" title="Reading progress" aria-hidden="true">
          <svg class="read-ring" viewBox="0 0 24 24">
            <circle class="ring-track" cx="12" cy="12" r="10"></circle>
            <circle class="ring-fill" cx="12" cy="12" r="10"></circle>
          </svg>
        </span>
      )}
    </div>

    {/* Right: a single contact CTA (→ the footer, where the socials and
        email live), plus the theme toggle. */}
    <nav aria-label="Actions" class="nav-row">
      {/* aria-label because narrow viewports hide the text span and leave only
          the (aria-hidden) envelope icon — without it the link has no name. */}
      <a href="#contact" class="header-cta" data-magnetic aria-label="Contact">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2"></rect>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
        </svg>
        <span>Contact</span>
      </a>

      {/* Divider always separates the primary action(s) from the theme utility. */}
      <span class="nav-divider" aria-hidden="true"></span>

      <button
        id="theme-toggle"
        class="theme-btn"
        aria-label="Toggle dark theme"
        type="button"
      >
        <!-- Sun Icon (visible in dark mode) -->
        <svg class="sun-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2"></path>
          <path d="M12 20v2"></path>
          <path d="m4.93 4.93 1.41 1.41"></path>
          <path d="m17.66 17.66 1.41 1.41"></path>
          <path d="M2 12h2"></path>
          <path d="M20 12h2"></path>
          <path d="m6.34 17.66-1.41 1.41"></path>
          <path d="m19.07 4.93-1.41 1.41"></path>
        </svg>
        <!-- Moon Icon (visible in light mode) -->
        <svg class="moon-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
        </svg>
      </button>
    </nav>
  </div>
</header>

<script>
  // Delegated on document so it keeps working across View Transitions swaps
  // (the button element is replaced on navigation, but document persists).
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('#theme-toggle');
    if (!btn) return;
    const current = document.documentElement.getAttribute('data-theme');
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    const color = next === 'dark' ? '#121214' : '#fcfcfc';
    const existing = document.querySelector('meta[name="theme-color"]');
    if (existing) existing.remove();
    const tc = document.createElement('meta');
    tc.name = 'theme-color';
    tc.content = color;
    document.head.prepend(tc);
  });

</script>
