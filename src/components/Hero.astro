---
import { intro } from '../lib/site';

const keepLetters = intro.nameShort.split('');
const dropLetters = intro.name.slice(intro.nameShort.length).split('');

// The role line reads "<lead> at Google" — split off the prefix so we can colour
// the company. When there's no recognised company we render the lead verbatim.
const company = intro.company ?? null;
const rolePrefix = company ? intro.statementLead.split(company)[0] : intro.statementLead;
---

<section class="hero" aria-label="Introduction">
  <div class="shell hero-inner">
    <div class="hero-cinematic-header">
      <h1 class="hero-name reveal reveal-delay-1" aria-label={`${intro.greeting} ${intro.name}`}>
        <span class="hero-greeting">{intro.greeting}</span>
        <span class="hero-fullname" id="hero-name" aria-hidden="true">{keepLetters.map((c) => <span class="nm-keep">{c}</span>)}{dropLetters.map((c) => <span class="nm-drop">{c}</span>)}<span class="nm-dot">.</span></span>
      </h1>

      {/* One statement: role + focus, merged. "Google" has a sleek gradient,
          and focus areas are modern interactive chips. Staggered reveal for polish. */}
      {/* Punctuation hugs the preceding word (comma sits inside Google's span;
          each pillar carries its trailing separator) so a line wrap never starts
          a line with a stray comma. */}
      <h2 class="hero-statement" aria-label={intro.statementLead + ", working on " + intro.pillars.map(p => p.label).join(", ")}>
        <span class="stagger-reveal" style="--stagger: 1" aria-hidden="true">{rolePrefix.trim()}</span>{company ? (
          <> <span class="stagger-reveal" style="--stagger: 2" aria-hidden="true"><span class="hero-company">{company}</span>,</span></>
        ) : null}<span class="hero-stmt-focus" aria-hidden="true"> <span class="stagger-reveal" style="--stagger: 3">{company ? 'working on' : ', working on'}</span> {intro.pillars.map((p, i) => {
          const isLast = i === intro.pillars.length - 1;
          const isSecondLast = i === intro.pillars.length - 2;
          // Punctuation that must stay glued to this pillar (never lead a line),
          // kept in a nowrap group with the inline-block pillar; the separator
          // after the group is where a line is allowed to break.
          const hug = isLast ? '.' : isSecondLast ? '' : ',';
          const after = isLast ? '' : isSecondLast ? ' and ' : ' ';
          return (<><span class="pillar-wrap"><span class="pillar stagger-reveal" style={`--c:${p.color}; --stagger: ${4 + i}`}>{p.label}</span>{hug}</span>{after}</>);
        })}</span>
      </h2>

      <p class="hero-invitation reveal reveal-delay-3">{intro.invitation}</p>

      <div class="hero-actions reveal reveal-delay-4">
        {/* The single hook: an "I'm feeling lucky" roulette. Click spins a real
            decelerating wheel that slot-machines through the site's sections,
            lands on a random one (theming the button in that section's colour),
            then flies you there. Reduced-motion picks instantly. See surprise.ts. */}
        <button
          type="button"
          class="surprise"
          data-surprise
          data-magnetic
          aria-label="Explore — jump to a random part of the site"
        >
          <span class="surprise-reel" aria-hidden="true">
            <span class="surprise-ico" data-surprise-ico></span>
            <span class="surprise-label" data-surprise-label>Explore</span>
          </span>
          <span class="surprise-arrow" aria-hidden="true">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 5v14M6 13l6 6 6-6" />
            </svg>
          </span>
        </button>

        {/* Writing is the heart of the site — kept reachable, but quiet. */}
        <a class="hero-quietlink" href="#writing" data-magnetic>
          <span>or just read my writing</span>
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 5v14M6 13l6 6 6-6" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
