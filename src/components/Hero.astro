---
import { intro } from '../lib/site';

const keepLetters = intro.nameShort.split('');
const dropLetters = intro.name.slice(intro.nameShort.length).split('');

const pillarIcons: Record<string, string> = {
  cloud:
    '<path d="M17.5 19a4.5 4.5 0 0 0 .5-8.97A6 6 0 0 0 6.34 9.5 4 4 0 0 0 7 19h10.5Z"/>',
  systems:
    '<circle cx="12" cy="5" r="2.4"/><circle cx="5" cy="18" r="2.4"/><circle cx="19" cy="18" r="2.4"/><path d="M12 7.4 6.5 16M12 7.4 17.5 16M7 18h10"/>',
  ai:
    '<path d="M12 3l1.8 4.9L18.5 9l-4.7 1.6L12 15l-1.8-4.4L5.5 9l4.7-1.1L12 3Z"/><path d="M18 14l.8 2.2L21 17l-2.2.8L18 20l-.8-2.2L15 17l2.2-.8L18 14Z"/>',
};
---

<section class="hero" aria-label="Introduction">
  <div class="hero-ambient-bg"></div>
  <div class="shell hero-inner">
    <div class="hero-cinematic-header">
      <h1 class="hero-name reveal reveal-delay-1" aria-label={`${intro.greeting} ${intro.name}`}>
        <span class="hero-greeting">{intro.greeting}</span>
        <span class="hero-fullname" id="hero-name" aria-hidden="true">{keepLetters.map((c) => <span class="nm-keep">{c}</span>)}{dropLetters.map((c) => <span class="nm-drop">{c}</span>)}<span class="nm-dot">.</span></span>
      </h1>

      <h2 class="hero-statement reveal reveal-delay-2">
        {intro.company ? intro.statementLead.split(intro.company).map((part, index, array) => (
          <>
            {part}
            {index < array.length - 1 && <span class="company-highlight">{intro.company}</span>}
          </>
        )) : intro.statementLead}{' '}
        {intro.pillars.map((p, i) => {
          const isLast = i === intro.pillars.length - 1;
          const prefix = i === 0 ? '' : isLast ? ' and ' : ' ';
          return (
            <>
              {prefix}
              <span class="pillar-wrap"><button type="button" class="pillar" data-pillar-id={i} aria-pressed="false" aria-controls={`card-${i}`} style={`--c:${p.color};--d:${0.6 + i * 0.18}s`}>{p.label}</button>{isLast ? '.' : ','}</span>
            </>
          );
        })}
      </h2>

      <p class="hero-bio reveal reveal-delay-3">{intro.bio}</p>

      <div class="hero-proof reveal reveal-delay-4">
        <p class="ach-lead">A few things I'm proud of — <span class="ach-lead-em">one per focus area</span>.</p>
        <ul class="hero-achievements" aria-label="Things I'm proud of">
          {intro.highlights.map((h, i) => (
            <li class="ach" data-card-id={i} id={`card-${i}`} style={`--c:${h.color}`}>
              <p class="ach-line" set:html={h.bodyHtml} />
              {(h.context || h.cta) && (
                <div class="ach-foot">
                  {h.context && (
                    <span class="ach-context">
                      <svg class="ach-glyph" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={pillarIcons[h.key] ?? ''} />
                      {h.context}
                    </span>
                  )}
                  {h.cta && (
                    <a class="ach-cta" href={h.cta.href} tabindex="-1">
                      <span>{h.cta.label}</span>
                      <span class="ach-cta-arrow" aria-hidden="true">→</span>
                    </a>
                  )}
                </div>
              )}
            </li>
          ))}
        </ul>

        {/* Pager: makes the deck legible as "3 highlights, one per area" and lets
            you jump between them. The active dot grows into its pillar colour. */}
        <div class="ach-pager" role="group" aria-label="Choose a highlight">
          {intro.highlights.map((h, i) => (
            <button type="button" class="ach-dot" data-dot={i} style={`--c:${h.color}`} aria-label={h.context ?? `Highlight ${i + 1}`}></button>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initPillarCycle() {
    const pillars = document.querySelectorAll('.pillar');
    const cards = document.querySelectorAll('.ach');
    const dots = Array.from(document.querySelectorAll('.ach-dot'));
    if (pillars.length === 0 || cards.length === 0) return;

    let currentIndex = 0;
    const CYCLE_DELAY = 4000;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function setActive(index) {
      pillars.forEach((p, i) => {
        if (i === index) {
          p.classList.add('is-active');
          p.setAttribute('aria-pressed', 'true');
        } else {
          p.classList.remove('is-active');
          p.setAttribute('aria-pressed', 'false');
        }
      });
      cards.forEach((c, i) => {
        const offset = (i - index + cards.length) % cards.length;
        (c as HTMLElement).style.setProperty('--stack', String(offset));
        const active = i === index;
        c.classList.toggle('is-active', active);
        // Only the front card is interactive; keep buried cards out of the tab order.
        const cta = c.querySelector('.ach-cta') as HTMLElement | null;
        if (cta) cta.tabIndex = active ? 0 : -1;
      });
      dots.forEach((d, i) => {
        const active = i === index;
        d.classList.toggle('is-active', active);
        d.setAttribute('aria-current', active ? 'true' : 'false');
      });
      currentIndex = index;
    }

    function startCycle() {
      stopCycle();
      if (reduceMotion) return;
      (window as any).__pillarCycle = setInterval(() => {
        const nextIndex = (currentIndex + 1) % pillars.length;
        setActive(nextIndex);
      }, CYCLE_DELAY);
    }

    function stopCycle() {
      if ((window as any).__pillarCycle) {
        clearInterval((window as any).__pillarCycle);
        (window as any).__pillarCycle = null;
      }
    }

    setActive(0);

    if (reduceMotion) {
      // The deck is flattened to a static column for reduced motion (see CSS),
      // so reveal and enable every card instead of a single cycling front one.
      cards.forEach((c) => {
        c.classList.add('is-active');
        const cta = c.querySelector('.ach-cta') as HTMLElement | null;
        if (cta) cta.tabIndex = 0;
      });
      return;
    }

    startCycle();

    // Pause the auto-cycle while the visitor is reading or steering the deck
    // (hovering anywhere in the proof block, or focusing a dot/CTA), so a card
    // never slides away from under the pointer.
    const proof = document.querySelector('.hero-proof');
    if (proof) {
      proof.addEventListener('pointerenter', stopCycle);
      proof.addEventListener('pointerleave', startCycle);
      proof.addEventListener('focusin', stopCycle);
      proof.addEventListener('focusout', startCycle);
    }

    // Dots: jump straight to a highlight (hover/focus to preview, click to pick).
    dots.forEach((dot, i) => {
      dot.addEventListener('mouseenter', () => setActive(i));
      dot.addEventListener('focus', () => setActive(i));
      dot.addEventListener('click', () => setActive(i));
    });

    pillars.forEach((pillar) => {
      const triggerActive = (e) => {
        stopCycle();
        const id = parseInt(e.target.getAttribute('data-pillar-id'), 10);
        if (!isNaN(id)) setActive(id);
      };

      pillar.addEventListener('mouseenter', triggerActive);
      pillar.addEventListener('focus', triggerActive);

      pillar.addEventListener('mouseleave', startCycle);
      pillar.addEventListener('blur', startCycle);
    });
  }

  if ((window as any).__pillarCycle) {
    clearInterval((window as any).__pillarCycle);
    (window as any).__pillarCycle = null;
  }
  document.addEventListener('astro:page-load', initPillarCycle);
</script>
