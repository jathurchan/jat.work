---
import { filters, lab, topicColor, topicLabel, formatDate } from '../lib/site';
import { sectionIcons, topicIcons } from '../lib/icons';
import { getPosts, buildSeries, partLabel } from '../lib/posts';

// The blog comes from src/content/blog/*.{md,mdx}, newest first.
const entries = await getPosts();

// ── Group posts into series + standalone ────────────────────────────────────
// A series (defined in site.yaml) collapses its parts into a single rich card;
// everything else renders as an individual card. Parts keep the order declared
// in the config (reading order), not publish date. buildSeries() is the same
// grouping the post pages use, so the feed and the in-post rails never drift.
const seriesGroups = buildSeries(entries).map((s) => ({ def: s, parts: s.parts }));

const inSeries = new Set(seriesGroups.flatMap((g) => g.parts.map((p) => p.slug)));
const standalone = entries.filter((e) => !inSeries.has(e.slug));

// "Latest" badge follows the single newest article across the whole feed.
const latestSlug = entries[0]?.slug;

// How many cards show before "Load more posts" reveals the next batch.
const PAGE_SIZE = 6;

// Content-aware toolbar: only surface controls that match what's actually
// published, so the rail grows with the writing instead of showing dead filters.
//   • topic tabs appear once there are ≥2 topics to choose between
//   • search appears once there are more posts than fit on one page
// (Today the feed is a single distributed-systems series, so both stay hidden.)
const presentFilters = filters.filter(
  (f) => f.id !== 'all' && entries.some((e) => (e.data.tags ?? []).includes(f.id)),
);
const showFilters = presentFilters.length >= 2;
const visibleFilters = showFilters ? [filters.find((f) => f.id === 'all')!, ...presentFilters] : [];
const showSearch = entries.length > PAGE_SIZE;
const showToolbar = showFilters || showSearch;
---

{/* ---------- Writing Section ---------- */}
<section id="writing" class="lab-section">
  <div class="section-lead section-rise">
    <span class="featured-eyebrow">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={sectionIcons['writing'] ?? ''} />
      {lab.eyebrow}
    </span>
    <h2 class="featured-lead-text">{lab.lead}</h2>
  </div>

  {/* Terminal-style filter rail with a live result count (mirrors the hero's
      monospace, HUD-flavoured voice). Controls only appear once the content
      warrants them — see showFilters / showSearch above. */}
  {showToolbar && (
    <div class="lab-toolbar">
      {showFilters ? (
        <div class="ftabs" role="group" aria-label="Filter by topic">
          <span class="ftabs-prompt" aria-hidden="true">~/</span>
          {visibleFilters.map((f) => (
            <button class="ftab" data-filter={f.id} aria-pressed={f.id === 'all' ? 'true' : 'false'} style={f.color ? `--accent: ${f.color}` : ''}>
              {f.label}
            </button>
          ))}
        </div>
      ) : (
        <span />
      )}
      <div class="lab-toolbar-end">
        {showSearch && (
          <div class="lab-search">
            <svg class="lab-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"></circle><path d="m21 21-4.3-4.3"></path></svg>
            <input type="search" id="jw-search" class="lab-search-input" placeholder="grep posts…" aria-label="Search posts by title, summary, or topic" autocomplete="off" spellcheck="false" />
          </div>
        )}
        <span class="lab-count" id="jw-labcount" aria-live="polite">{entries.length} posts</span>
      </div>
    </div>
  )}

  <div class="lab-grid" id="jw-worklist" data-page-size={PAGE_SIZE}>
    {entries.length === 0 ? (
      <div class="lab-empty">
        <svg class="lab-empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 20h4L19 9l-4-4L4 16v4Z"></path>
          <path d="M14 6l4 4"></path>
        </svg>
        <h3 class="lab-empty-title">The first words are coming</h3>
        <p class="lab-empty-text">I'm currently writing about cloud computing, distributed systems, and AI — what I build, break, and learn. Check back soon.</p>
      </div>
    ) : (
      <>
        {/* ── Series cards: one per series, parts listed in reading order ── */}
        {seriesGroups.map((g) => {
          const color = topicColor[g.def.topic] || 'var(--ink)';
          const isLatest = g.parts.some((p) => p.slug === latestSlug);
          return (
            <article
              class="lab-card lab-card--feature lab-card--series"
              data-tags={JSON.stringify([g.def.topic])}
              data-count={g.parts.length}
              style={`--card-color: ${color};`}
            >
              <div class="lab-card-body">
                <div class="lab-card-top">
                  <span class="lab-kinds">
                    <span class="lab-kind" style={`--chip-color: ${color};`}>
                      {topicIcons[g.def.topic] && (
                        <svg class="lab-kind-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={topicIcons[g.def.topic]} />
                      )}
                      {topicLabel[g.def.topic] ?? 'Series'}
                    </span>
                  </span>
                  <span class="lab-series-badge">{g.parts.length}-part series</span>
                  {isLatest && <span class="lab-latest">Latest</span>}
                </div>

                <h3 class="lab-card-title">
                  <a class="lab-series-name" href={`/blog/${g.parts[0].slug}`}>{g.def.name}</a>
                </h3>
                <p class="lab-card-blurb">{g.def.blurb}</p>

                <ol class="lab-series-parts">
                  {g.parts.map((p, i) => (
                    <li>
                      <a class="lab-series-part" href={`/blog/${p.slug}`}>
                        <span class="lab-series-num">{String(i + 1).padStart(2, '0')}</span>
                        <span class="lab-series-ptitle">{partLabel(p.data.title)}</span>
                        <span class="lab-series-pdate">{formatDate(p.data.pubDate)}</span>
                        <span class="lab-series-arrow" aria-hidden="true">→</span>
                      </a>
                    </li>
                  ))}
                </ol>
              </div>

              <div class="lab-feature-aside" aria-hidden="true">
                <svg class="lab-feature-glyph" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" set:html={topicIcons[g.def.topic] ?? ''} />
              </div>
            </article>
          );
        })}

        {/* ── Standalone posts ── */}
        {standalone.map((e) => {
          const tags = e.data.tags?.length ? e.data.tags : ['all'];
          const primaryTag = tags[0];
          const cardColor = topicColor[primaryTag] || 'var(--ink)';
          const isLatest = e.slug === latestSlug;

          return (
            <a
              href={`/blog/${e.slug}`}
              class="lab-card"
              data-tags={JSON.stringify(e.data.tags ?? [])}
              data-count="1"
              style={`--card-color: ${cardColor};`}
            >
              <div class="lab-card-body">
                <div class="lab-card-top">
                  <span class="lab-kinds">
                    {tags.map((tag) => (
                      <span class="lab-kind" style={topicColor[tag] ? `--chip-color: ${topicColor[tag]};` : ''}>
                        {topicIcons[tag] && (
                          <svg class="lab-kind-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={topicIcons[tag]} />
                        )}
                        {topicLabel[tag] ?? 'Article'}
                      </span>
                    ))}
                  </span>
                  {isLatest && <span class="lab-latest">Latest</span>}
                  <span class="lab-arrow" aria-hidden="true">→</span>
                </div>

                <h3 class="lab-card-title">{e.data.title}</h3>
                <p class="lab-card-blurb">{e.data.blurb}</p>

                <div class="lab-card-foot">
                  <span class="lab-date">{formatDate(e.data.pubDate)}</span>
                </div>
              </div>
            </a>
          );
        })}
      </>
    )}
  </div>

  <p class="lab-noresults" id="jw-noresults" role="status" hidden>
    No posts match — try another topic or clear the search.
  </p>

  {entries.length > PAGE_SIZE && (
    <div class="lab-more">
      <button type="button" id="jw-loadmore" class="lab-more-btn">
        <span class="lab-more-label">Load more posts</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg>
      </button>
    </div>
  )}
</section>
